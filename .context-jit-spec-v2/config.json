  "invariants": [
    {
      "id": "completed-task-has-verification",
      "class": "requires-edge",
      "block": "tasks",
      "where": {
        "status": "completed"
      },
      "relation_types": [
        "verification_verifies_item"
      ],
      "direction": "as_child",
      "severity": "error",
      "message": "Completed task '{id}' has no verification edge (verification_verifies_item)"
    },
    {
      "id": "decision-cites-forcing-artifact",
      "class": "requires-edge",
      "block": "decisions",
      "relation_types": [
        "decision_addresses_issue",
        "decision_addresses_feature",
        "decision_addresses_gap"
      ],
      "direction": "as_parent",
      "severity": "error",
      "message": "Decision '{id}' cites no forcing artifact (decision_addresses_issue|feature|gap edge)"
    },
    {
      "id": "task-completed-gap-closed",
      "class": "status-consistency",
      "block": "tasks",
      "relation_types": [
        "task_addresses_gap"
      ],
      "direction": "as_parent",
      "when_bucket": "complete",
      "require_target_bucket": "complete",
      "severity": "warning",
      "message": "Completed task '{id}' addresses a gap that is not closed"
    },
    {
      "id": "task-completed-feature-complete",
      "class": "status-consistency",
      "block": "tasks",
      "relation_types": [
        "task_addresses_feature"
      ],
      "direction": "as_parent",
      "when_bucket": "complete",
      "require_target_bucket": "complete",
      "severity": "warning",
      "message": "Completed task '{id}' addresses a feature that is not complete"
    },
    {
      "id": "verification-passed-task-complete",
      "class": "status-consistency",
      "block": "verification",
      "relation_types": [
        "verification_verifies_item"
      ],
      "direction": "as_parent",
      "when_bucket": "complete",
      "require_target_bucket": "complete",
      "severity": "error",
      "message": "Passed verification '{id}' verifies a task that is not completed"
    },
    {
      "id": "task-not-on-superseded-decision",
      "class": "status-consistency",
      "block": "tasks",
      "relation_types": [
        "task_governed_by_decision"
      ],
      "direction": "as_parent",
      "forbid_target_bucket": "unknown",
      "severity": "warning",
      "message": "Task '{id}' is governed by a superseded or cancelled decision"
    },
    {
      "id": "decision-grounded-by-axiom-or-friction-or-authority",
      "class": "requires-edge",
      "block": "decisions",
      "relation_types": [
        "axiom_grounds_decision",
        "friction_item_addressed_by_decision",
        "authority_doc_grounds_decision"
      ],
      "direction": "as_child",
      "severity": "warning",
      "message": "Decision {id} has no grounding edge (axiom / friction-item / authority-doc); ungrounded decisions risk drifting from arc canon"
    },
    {
      "id": "concept-referenced-by-decision-or-grounded",
      "class": "requires-edge",
      "block": "concepts",
      "relation_types": [
        "concept_referenced_in_decision",
        "authority_doc_grounds_concept",
        "friction_item_addressed_by_concept"
      ],
      "direction": "as_child",
      "severity": "warning",
      "message": "Concept {id} has no incoming edge (no decision references it; no authority-doc grounds it; no friction-item addresses it); orphan concepts are arc noise"
    },
    {
      "id": "dispatch-mode-realizes-decision",
      "class": "requires-edge",
      "block": "dispatch-modes",
      "relation_types": [
        "dispatch_mode_realizes_decision"
      ],
      "direction": "as_parent",
      "severity": "error",
      "message": "Dispatch mode {id} realizes no decision (dispatch_mode_realizes_decision edge required); mode without decision-grounding is undefined"
    },
    {
      "id": "friction-item-files-to-gap-or-addressed",
      "class": "requires-edge",
      "block": "friction-items",
      "relation_types": [
        "friction_item_files_to_gap",
        "friction_item_addressed_by_decision",
        "friction_item_addressed_by_concept"
      ],
      "direction": "as_parent",
      "severity": "warning",
      "message": "Friction item {id} has no outgoing edge (no FGAP filed, no decision addressing, no concept addressing); lost-friction items have no implementation path"
    },
    {
      "id": "authority-doc-grounds-something",
      "class": "requires-edge",
      "block": "authority-docs",
      "relation_types": [
        "authority_doc_grounds_decision",
        "authority_doc_grounds_concept",
        "authority_doc_names_dispatch_mode"
      ],
      "direction": "as_parent",
      "severity": "warning",
      "message": "Authority doc {id} grounds nothing (no decision / concept / dispatch-mode edge); orphan authority does not drive the arc"
    },
    {
      "id": "v1-supersession-targets-v2-item",
      "class": "requires-edge",
