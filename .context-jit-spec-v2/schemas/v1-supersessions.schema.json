{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pi-context://schemas/v1-supersessions",
  "version": "1.0.0",
  "title": "V1 Supersessions",
  "description": "Per-v1-section supersession tracking — maps each v1 section reference to the v2 substrate items that supersede or extend it. Surfaces 'coverage-vs-v1' for the canonical lens.",
  "type": "object",
  "required": ["supersessions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string" },
    "supersessions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "v1_section_reference", "supersession_kind", "created_by", "created_at"],
        "properties": {
          "id": { "type": "string", "pattern": "^VSUP-\\d{3}$" },
          "v1_section_reference": { "type": "string", "description": "Section identifier in v1 spec (e.g. 'v1 §4 D4', 'v1 §0 P1', 'v1 §5 Success Criteria')" },
          "supersession_kind": { "type": "string", "enum": ["carried_forward_unchanged", "extended", "rewritten", "removed", "replaced_by_new_decision"] },
          "superseded_by_v2_items": {
            "type": "array",
            "items": { "type": "string", "description": "ID of v2 substrate item (AX-NNN, DEC-NNNN, CONCEPT-NNN, MODE-NNN, FGAP-NNN)" }
          },
          "notes": { "type": "string", "description": "What changed + why" },
          "created_by": { "type": "string" },
          "created_at": { "type": "string" }
        }
      }
    }
  }
}
