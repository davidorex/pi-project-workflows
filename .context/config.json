  "invariants": [
    {
      "id": "completed-task-has-verification",
      "class": "requires-edge",
      "block": "tasks",
      "where": {
        "status": "completed"
      },
      "relation_types": [
        "verification_verifies_item"
      ],
      "direction": "as_child",
      "severity": "error",
      "message": "Completed task '{id}' has no verification edge (verification_verifies_item)"
    },
    {
      "id": "decision-cites-forcing-artifact",
      "class": "requires-edge",
      "block": "decisions",
      "relation_types": [
        "decision_addresses_issue",
        "decision_addresses_feature",
        "decision_addresses_gap"
      ],
      "direction": "as_parent",
      "severity": "error",
      "message": "Decision '{id}' cites no forcing artifact (decision_addresses_issue|feature|gap edge)"
    },
    {
      "id": "task-completed-gap-closed",
      "class": "status-consistency",
      "block": "tasks",
      "relation_types": [
        "task_addresses_gap"
      ],
      "direction": "as_parent",
      "when_bucket": "complete",
      "require_target_bucket": "complete",
      "severity": "warning",
      "message": "Completed task '{id}' addresses a gap that is not closed"
    },
    {
      "id": "task-completed-feature-complete",
      "class": "status-consistency",
      "block": "tasks",
      "relation_types": [
        "task_addresses_feature"
      ],
      "direction": "as_parent",
      "when_bucket": "complete",
      "require_target_bucket": "complete",
      "severity": "warning",
      "message": "Completed task '{id}' addresses a feature that is not complete"
    },
    {
      "id": "verification-passed-task-complete",
      "class": "status-consistency",
      "block": "verification",
      "relation_types": [
        "verification_verifies_item"
      ],
      "direction": "as_parent",
      "when_bucket": "complete",
      "require_target_bucket": "complete",
      "severity": "error",
      "message": "Passed verification '{id}' verifies a task that is not completed"
    },
    {
      "id": "task-not-on-superseded-decision",
      "class": "status-consistency",
      "block": "tasks",
      "relation_types": [
        "task_governed_by_decision"
      ],
      "direction": "as_parent",
      "forbid_target_bucket": "unknown",
      "severity": "warning",
      "message": "Task '{id}' is governed by a superseded or cancelled decision"
    },
    {
      "id": "decision-articulates-convention",
      "class": "requires-edge",
      "block": "decisions",
      "relation_types": [
        "item_governed_by_convention",
        "item_acknowledges_missing_convention"
      ],
      "direction": "as_parent",
      "severity": "error",
      "message": "Decision '{id}' articulates no governing convention — add an item_governed_by_convention edge to a convention, or an item_acknowledges_missing_convention edge to a missing-convention gap"
    },
    {
      "id": "feature-articulates-convention",
      "class": "requires-edge",
      "block": "features",
      "relation_types": [
        "item_governed_by_convention",
        "item_acknowledges_missing_convention"
      ],
      "direction": "as_parent",
      "severity": "error",
      "message": "Feature '{id}' articulates no governing convention — add an item_governed_by_convention edge to a convention, or an item_acknowledges_missing_convention edge to a missing-convention gap"
    },
    {
      "id": "task-articulates-convention",
      "class": "requires-edge",
      "block": "tasks",
      "relation_types": [
        "item_governed_by_convention",
        "item_acknowledges_missing_convention"
      ],
      "direction": "as_parent",
      "severity": "error",
      "message": "Task '{id}' articulates no governing convention — add an item_governed_by_convention edge to a convention, or an item_acknowledges_missing_convention edge to a missing-convention gap"
    },
    {
      "id": "decision-shows-derivation",
      "class": "requires-edge",
