{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schema_version",
    "sessions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "timestamp",
          "focus",
          "current_status",
          "next_steps"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SESSION-\\d{3}$"
          },
          "timestamp": {
            "type": "string",
            "description": "ISO-8601 with local offset"
          },
          "focus": {
            "type": "string",
            "description": "1-2 sentence summary of what the session covered"
          },
          "discoveries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "questions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "decisions_made": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "current_status": {
            "type": "string",
            "description": "Prose summary of where the project stands at session end"
          },
          "next_steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
