{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Project Identity",
	"description": "Identity and scope. What this project is, what it aims to do, what is in and out of scope. The anchor all other blocks reference. Contains name, vision, core value proposition, goals with success criteria, constraints, and current status.",
	"type": "object",
	"required": ["name", "description", "core_value"],
	"properties": {
		"name": { "type": "string" },
		"description": { "type": "string", "x-prompt-budget": { "tokens": 1000, "words": 800 } },
		"vision": {
			"type": "string",
			"description": "What this project aims to achieve and why it matters",
			"x-prompt-budget": { "tokens": 1000, "words": 800 }
		},
		"core_value": {
			"type": "string",
			"description": "One-sentence value proposition",
			"x-prompt-budget": { "tokens": 1000, "words": 800 }
		},
		"target_users": {
			"type": "array",
			"items": { "type": "string" }
		},
		"constraints": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["type", "description"],
				"properties": {
					"type": { "type": "string" },
					"description": { "type": "string", "x-prompt-budget": { "tokens": 1000, "words": 800 } }
				}
			}
		},
		"scope_boundaries": {
			"type": "object",
			"required": ["in", "out"],
			"properties": {
				"in": { "type": "array", "items": { "type": "string" } },
				"out": { "type": "array", "items": { "type": "string" } }
			}
		},
		"goals": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["id", "description"],
				"properties": {
					"id": { "type": "string" },
					"description": { "type": "string", "x-prompt-budget": { "tokens": 1000, "words": 800 } },
					"success_criteria": {
						"type": "array",
						"items": { "type": "string", "x-prompt-budget": { "tokens": 1000, "words": 800 } }
					}
				}
			}
		},
		"status": { "type": "string", "enum": ["inception", "planning", "development", "maintenance", "complete"] },
		"repository": { "type": "string" },
		"stack": { "type": "array", "items": { "type": "string" } }
	}
}
