{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "ADRs",
	"description": "Architecture Decision Records (Nygard 2011). Each ADR captures a load-bearing design decision with its context, the options considered, the decision itself, its consequences, and its lifecycle state. ADRs are L2 specification-layer artifacts — they evolve with design but are durable across iterations. Decided-state transitions require user authority per the authorship-matrix principle.",
	"type": "object",
	"required": ["adrs"],
	"properties": {
		"adrs": {
			"type": "array",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["id", "title", "status", "context", "decision", "consequences", "created_by", "created_at"],
				"properties": {
					"id": { "type": "string", "pattern": "^ADR-\\d{4}$" },
					"title": { "type": "string" },
					"status": {
						"type": "string",
						"enum": ["proposed", "under-review", "decided", "superseded", "deprecated"]
					},
					"context": {
						"type": "string",
						"description": "The forces at play — technical, organizational, historical — that the decision addresses"
					},
					"decision": {
						"type": "string",
						"description": "The position taken. For proposed ADRs this is the recommended direction; for decided ADRs this is the final choice."
					},
					"options_considered": {
						"type": "array",
						"items": {
							"type": "object",
							"additionalProperties": false,
							"required": ["label", "description"],
							"properties": {
								"label": { "type": "string" },
								"description": { "type": "string" },
								"tradeoffs": { "type": "string" },
								"rejected_reason": { "type": "string" }
							}
						}
					},
					"consequences": {
						"type": "array",
						"items": { "type": "string" },
						"description": "What becomes easier, harder, or impossible once the decision is in effect"
					},
					"supersedes": { "type": "array", "items": { "type": "string" } },
					"superseded_by": { "type": "string" },
					"related_findings": { "type": "array", "items": { "type": "string" } },
					"related_features": { "type": "array", "items": { "type": "string" } },
					"related_gaps": { "type": "array", "items": { "type": "string" } },
					"references": {
						"type": "array",
						"items": {
							"type": "object",
							"additionalProperties": false,
							"required": ["label"],
							"properties": {
								"label": { "type": "string" },
								"path": { "type": "string" },
								"lines": { "type": "string" }
							}
						}
					},
					"created_by": { "type": "string" },
					"created_at": { "type": "string" },
					"decided_by": { "type": "string" },
					"decided_at": { "type": "string" }
				}
			}
		}
	},
	"x-lifecycle": {
		"field": "status",
		"states": ["proposed", "under-review", "decided", "superseded", "deprecated"],
		"transitions": [
			{ "from": "proposed", "to": "under-review", "required_authority": "any" },
			{ "from": "under-review", "to": "proposed", "required_authority": "any" },
			{ "from": "under-review", "to": "decided", "required_authority": "user" },
			{ "from": "decided", "to": "superseded", "required_authority": "user" },
			{ "from": "decided", "to": "deprecated", "required_authority": "user" }
		],
		"note": "AJV draft-07 cannot enforce transition validity; this block is metadata for future framework-level state-machine validation (FGAP-005)."
	}
}
