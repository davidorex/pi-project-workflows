{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Architecture",
	"description": "How the system is structured. Modules, boundaries, patterns, dependencies. The map that constrains implementation decisions. Consumed by planning agents to understand what exists before proposing changes.",
	"type": "object",
	"required": ["modules"],
	"properties": {
		"modules": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name", "file", "responsibility"],
				"properties": {
					"name": { "type": "string" },
					"file": { "type": "string" },
					"responsibility": { "type": "string", "x-prompt-budget": { "tokens": 1000, "words": 800 } },
					"dependencies": { "type": "array", "items": { "type": "string" } },
					"lines": { "type": "integer" }
				}
			}
		},
		"patterns": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name", "description"],
				"properties": {
					"name": { "type": "string" },
					"description": { "type": "string", "x-prompt-budget": { "tokens": 1000, "words": 800 } },
					"used_in": { "type": "array", "items": { "type": "string" } }
				}
			}
		},
		"boundaries": {
			"type": "array",
			"items": { "type": "string" }
		},
		"compilation_pipeline": {
			"type": "object",
			"required": ["description", "stages"],
			"properties": {
				"description": { "type": "string" },
				"stages": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["name", "input", "output"],
						"properties": {
							"name": { "type": "string" },
							"input": { "type": "string" },
							"output": { "type": "string" },
							"description": { "type": "string" }
						}
					}
				},
				"intermediate_representation": { "type": "string" }
			}
		},
		"execution_model": {
			"type": "object",
			"required": ["description"],
			"properties": {
				"description": { "type": "string" },
				"conservative_plan": { "type": "string" },
				"layer_execution": { "type": "string" },
				"step_types": {
					"type": "array",
					"items": { "type": "string" }
				},
				"three_tier_resolution": {
					"type": "object",
					"required": ["pattern", "tiers"],
					"properties": {
						"pattern": { "type": "string" },
						"tiers": {
							"type": "array",
							"items": {
								"type": "object",
								"required": ["level", "path"],
								"properties": {
									"level": { "type": "string" },
									"path": { "type": "string" },
									"priority": { "type": "integer" }
								}
							}
						},
						"used_by": { "type": "array", "items": { "type": "string" } }
					}
				},
				"pause_resume": {
					"type": "object",
					"properties": {
						"mechanisms": { "type": "array", "items": { "type": "string" } },
						"statuses": { "type": "array", "items": { "type": "string" } },
						"keybindings": {
							"type": "object",
							"additionalProperties": { "type": "string" }
						}
					}
				}
			}
		},
		"dispatch_design": {
			"type": "object",
			"required": ["method", "rationale"],
			"properties": {
				"method": { "type": "string" },
				"rationale": { "type": "string" },
				"alternative_considered": { "type": "string" },
				"alternative_rationale": { "type": "string" },
				"parallelism_model": { "type": "string" }
			}
		}
	}
}
