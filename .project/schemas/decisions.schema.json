{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pi-context://schemas/sub-0c813fd84348d4c2/decisions",
  "version": "1.0.0",
  "title": "decisions",
  "type": "object",
  "required": [
    "decisions"
  ],
  "properties": {
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^DEC-\\d{4}$"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "context": {
            "type": "string"
          },
          "decision": {
            "type": "string"
          },
          "consequences": {
            "type": "array"
          },
          "supersedes": {
            "type": "array"
          },
          "related_findings": {
            "type": "array"
          },
          "related_features": {
            "type": "array"
          },
          "related_gaps": {
            "type": "array"
          },
          "references": {
            "type": "array"
          },
          "created_by": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "enacted_by": {
            "type": "string"
          },
          "enacted_at": {
            "type": "string"
          },
          "options_considered": {
            "type": "array"
          },
          "superseded_by": {
            "type": "string"
          },
          "oid": {
            "type": "string",
            "pattern": "^[0-9a-f]{32}$",
            "description": "Content-independent substrate-stable item identity (content-addressed substrate identity, Cycle 3). Minted once at item birth via mintOid(substrate_id); immutable across content versions. Optional in the schema so pre-Cycle-3 items validate; stamped on next write."
          },
          "content_hash": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "description": "SHA-256 (hex) of the RFC-8785-canonical content projection of this item (metadata fields excluded). Recomputed on every stamping write; moves with content, stable across metadata-only churn."
          },
          "content_parent": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "description": "content_hash of the immediately-prior version of this item; set on a content-changing update, absent on the first (v1) version. Forms the per-item content version chain."
          }
        }
      }
    }
  }
}
