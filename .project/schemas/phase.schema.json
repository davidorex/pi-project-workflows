{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Phase",
	"description": "A unit of planned implementation work. Contains intent, success criteria, specs (decomposed work items), status lifecycle (planned, in-progress, completed), and dependency tracking. Phases live in .project/phases/ as individual files.",
	"type": "object",
	"required": ["number", "name", "intent", "status"],
	"properties": {
		"number": { "type": "integer" },
		"name": { "type": "string" },
		"intent": { "type": "string" },
		"status": { "type": "string", "enum": ["planned", "in-progress", "completed"] },
		"success_criteria": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["criterion", "verify_method"],
				"properties": {
					"criterion": { "type": "string" },
					"verify_method": { "type": "string", "enum": ["command", "inspect", "human"] }
				}
			}
		},
		"specs": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["number", "name", "intent", "status"],
				"properties": {
					"number": { "type": "integer" },
					"name": { "type": "string" },
					"intent": { "type": "string" },
					"status": { "type": "string", "enum": ["planned", "in-progress", "completed"] },
					"acceptance_criteria": {
						"type": "array",
						"items": { "type": "string" }
					}
				}
			}
		},
		"dependencies": {
			"type": "array",
			"items": { "type": "integer" }
		},
		"artifacts_produced": {
			"type": "array",
			"items": { "type": "string" }
		}
	}
}
