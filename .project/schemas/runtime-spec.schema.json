{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Runtime Spec",
	"type": "object",
	"required": ["step_types", "expression_syntax", "dispatch_protocol", "state_management", "tui", "completion"],
	"properties": {
		"step_types": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name", "semantics", "executor_module"],
				"properties": {
					"name": { "type": "string" },
					"semantics": { "type": "string" },
					"executor_module": { "type": "string" },
					"fields": {
						"type": "array",
						"items": {
							"type": "object",
							"required": ["name", "description"],
							"properties": {
								"name": { "type": "string" },
								"type": { "type": "string" },
								"description": { "type": "string" },
								"required": { "type": "boolean" }
							}
						}
					},
					"output_behavior": { "type": "string" }
				}
			}
		},
		"expression_syntax": {
			"type": "object",
			"required": ["delimiter", "capabilities"],
			"properties": {
				"delimiter": { "type": "string" },
				"capabilities": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["name", "description"],
						"properties": {
							"name": { "type": "string" },
							"description": { "type": "string" },
							"example": { "type": "string" }
						}
					}
				},
				"scope_keys": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["key", "description"],
						"properties": {
							"key": { "type": "string" },
							"description": { "type": "string" }
						}
					}
				},
				"pipe_filters": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["name", "description"],
						"properties": {
							"name": { "type": "string" },
							"description": { "type": "string" },
							"example": { "type": "string" }
						}
					}
				},
				"limitations": {
					"type": "array",
					"items": { "type": "string" }
				}
			}
		},
		"dispatch_protocol": {
			"type": "object",
			"required": ["command", "subprocess_environment", "completion_detection", "output_extraction"],
			"properties": {
				"command": { "type": "string" },
				"subprocess_environment": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["aspect", "description"],
						"properties": {
							"aspect": { "type": "string" },
							"description": { "type": "string" }
						}
					}
				},
				"event_stream": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["event", "description"],
						"properties": {
							"event": { "type": "string" },
							"description": { "type": "string" }
						}
					}
				},
				"completion_detection": { "type": "string" },
				"output_extraction": { "type": "string" },
				"usage_tracking": { "type": "string" },
				"error_detection": { "type": "string" },
				"model_override": { "type": "string" },
				"tool_filtering": { "type": "string" }
			}
		},
		"state_management": {
			"type": "object",
			"required": ["run_directory"],
			"properties": {
				"run_directory": {
					"type": "object",
					"required": ["path", "contents"],
					"properties": {
						"path": { "type": "string" },
						"contents": {
							"type": "array",
							"items": {
								"type": "object",
								"required": ["name", "description"],
								"properties": {
									"name": { "type": "string" },
									"description": { "type": "string" }
								}
							}
						}
					}
				},
				"statuses": {
					"type": "array",
					"items": { "type": "string" }
				},
				"persistence_method": { "type": "string" },
				"step_statuses": {
					"type": "array",
					"items": { "type": "string" }
				}
			}
		},
		"tui": {
			"type": "object",
			"required": ["widget"],
			"properties": {
				"widget": {
					"type": "object",
					"required": ["description"],
					"properties": {
						"description": { "type": "string" },
						"api_method": { "type": "string" },
						"shows": { "type": "array", "items": { "type": "string" } }
					}
				},
				"dashboard": {
					"type": "object",
					"properties": {
						"description": { "type": "string" },
						"api_method": { "type": "string" },
						"shows": { "type": "array", "items": { "type": "string" } }
					}
				},
				"keybindings": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["key", "action"],
						"properties": {
							"key": { "type": "string" },
							"action": { "type": "string" }
						}
					}
				},
				"indicators": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["symbol", "meaning"],
						"properties": {
							"symbol": { "type": "string" },
							"meaning": { "type": "string" }
						}
					}
				}
			}
		},
		"completion": {
			"type": "object",
			"required": ["forms"],
			"properties": {
				"forms": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["name", "description"],
						"properties": {
							"name": { "type": "string" },
							"description": { "type": "string" },
							"fields": { "type": "array", "items": { "type": "string" } },
							"syntax": { "type": "string" }
						}
					}
				},
				"scope": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["key", "description"],
						"properties": {
							"key": { "type": "string" },
							"description": { "type": "string" }
						}
					}
				}
			}
		},
		"events": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name", "description"],
				"properties": {
					"name": { "type": "string" },
					"description": { "type": "string" },
					"payload": { "type": "string" }
				}
			}
		},
		"artifacts": {
			"type": "object",
			"properties": {
				"description": { "type": "string" },
				"spec_fields": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["name", "description"],
						"properties": {
							"name": { "type": "string" },
							"description": { "type": "string" }
						}
					}
				},
				"patterns": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["name", "description"],
						"properties": {
							"name": { "type": "string" },
							"description": { "type": "string" },
							"example": { "type": "string" }
						}
					}
				}
			}
		},
		"naming": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["concept", "name"],
				"properties": {
					"concept": { "type": "string" },
					"name": { "type": "string" },
					"not": { "type": "string" },
					"rationale": { "type": "string" }
				}
			}
		},
		"core_types": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name", "description"],
				"properties": {
					"name": { "type": "string" },
					"description": { "type": "string" },
					"key_fields": {
						"type": "array",
						"items": {
							"type": "object",
							"required": ["name", "type"],
							"properties": {
								"name": { "type": "string" },
								"type": { "type": "string" },
								"description": { "type": "string" }
							}
						}
					}
				}
			}
		}
	}
}
