{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project State",
  "type": "object",
  "required": [
    "current_phase",
    "current_spec",
    "test_count"
  ],
  "properties": {
    "current_phase": {
      "type": "integer"
    },
    "current_spec": {
      "type": "integer"
    },
    "test_count": {
      "type": "integer"
    },
    "last_commit": {
      "type": "string"
    },
    "accumulated_context": {
      "type": "object",
      "properties": {
        "decisions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "todos": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "required": [
                  "severity",
                  "description"
                ],
                "properties": {
                  "severity": {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high",
                      "critical"
                    ]
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            ]
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "session": {
      "type": "object",
      "properties": {
        "last_action": {
          "type": "string"
        },
        "next_action": {
          "type": "string"
        }
      }
    }
  }
}
