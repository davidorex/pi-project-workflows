{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "issues-block",
	"description": "POC A minimal schema for the issues block. Mirrors the candidate articulation's typed-memory-store invariant (validated writes) at POC fidelity; AJV not invoked here per POC scope.",
	"type": "object",
	"required": ["issues"],
	"properties": {
		"issues": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["id", "title"],
				"properties": {
					"id": { "type": "string", "pattern": "^issue-\\d{3}$" },
					"title": { "type": "string" },
					"status": { "type": "string", "enum": ["open", "in_progress", "resolved", "deferred"] },
					"body": { "type": "string" }
				},
				"additionalProperties": false
			}
		}
	},
	"additionalProperties": false
}
