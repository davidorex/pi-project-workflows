{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pi-context://schemas/framework-gaps",
  "version": "1.1.1",
  "title": "Framework Gaps",
  "description": "Capability gaps in the framework — pieces that must exist natively for the target artifact-ownership model to be expressible as configuration rather than hand-enactment. Each gap carries evidence (file + line references), impact, canonical engineering vocabulary for the missing capability, proposed resolution, and lifecycle state. Framework gaps are distinct from feature-level defects: they describe what the framework cannot yet express at all, not bugs in expressible functionality.",
  "type": "object",
  "required": [
    "gaps"
  ],
  "properties": {
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status",
          "package",
          "description",
          "evidence",
          "impact",
          "proposed_resolution",
          "created_by",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^FGAP-\\d{3}$"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "identified",
              "accepted",
              "in-progress",
              "closed",
              "wontfix",
              "superseded_by"
            ]
          },
          "priority": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "package": {
            "type": "string"
          },
          "layer": {
            "type": "string",
            "enum": [
              "L1",
              "L2",
              "L3",
              "L4",
              "L5"
            ]
          },
          "description": {
            "type": "string",
            "x-prompt-budget": {
              "tokens": 1000,
              "words": 800
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "file",
                "reference"
              ],
              "properties": {
                "file": {
                  "type": "string"
                },
                "lines": {
                  "type": "string"
                },
                "reference": {
                  "type": "string",
                  "description": "What specifically at this location demonstrates the gap",
                  "x-prompt-budget": {
                    "tokens": 1000,
                    "words": 800
                  }
                }
              }
            }
          },
          "impact": {
            "type": "string",
            "x-prompt-budget": {
              "tokens": 1000,
              "words": 800
            }
          },
          "canonical_vocabulary": {
            "type": "string",
            "description": "The established engineering term for the capability that is missing"
          },
          "proposed_resolution": {
            "type": "string",
            "x-prompt-budget": {
              "tokens": 1000,
              "words": 800
            }
          },
          "related_features": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_decisions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_by": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "closed_by": {
            "type": "string"
          },
          "closed_at": {
            "type": "string"
          },
          "oid": {
            "type": "string",
            "pattern": "^[0-9a-f]{32}$",
            "description": "Content-independent substrate-stable item identity (content-addressed substrate identity, Cycle 3). Minted once at item birth via mintOid(substrate_id); immutable across content versions. Optional in the schema so pre-Cycle-3 items validate; stamped on next write."
          },
          "content_hash": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "description": "SHA-256 (hex) of the RFC-8785-canonical content projection of this item (metadata fields excluded). Recomputed on every stamping write; moves with content, stable across metadata-only churn."
          },
          "content_parent": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "description": "content_hash of the immediately-prior version of this item; set on a content-changing update, absent on the first (v1) version. Forms the per-item content version chain."
          }
        }
      }
    }
  },
  "x-lifecycle": {
    "field": "status",
    "states": [
      "identified",
      "accepted",
      "in-progress",
      "closed",
      "wontfix",
      "superseded_by"
    ],
    "transitions": [
      {
        "from": "identified",
        "to": "accepted",
        "required_authority": "user"
      },
      {
        "from": "identified",
        "to": "wontfix",
        "required_authority": "user"
      },
      {
        "from": "accepted",
        "to": "in-progress",
        "required_authority": "any"
      },
      {
        "from": "in-progress",
        "to": "closed",
        "required_authority": "any"
      },
      {
        "from": "identified",
        "to": "superseded_by",
        "required_authority": "user"
      }
    ]
  }
}