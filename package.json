{
  "name": "pi-workflows",
  "version": "0.1.0",
  "description": "Workflow orchestration extension for pi",
  "license": "MIT",
  "type": "module",
  "keywords": ["pi-package"],
  "pi": {
    "extensions": ["./index.ts"]
  },
  "files": [
    "*.ts",
    "src/",
    "*.md",
    "demo/"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test src/*.test.ts",
    "test:integration": "node --experimental-strip-types --test src/*.test.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "yaml": "^2.7.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  }
}
