{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"description": "What the project must deliver. Functional and non-functional requirements with MoSCoW priority and lifecycle states (proposed, accepted, implemented, verified). The contract between intent and implementation.",
	"title": "Requirements",
	"type": "object",
	"required": [
		"requirements"
	],
	"properties": {
		"requirements": {
			"type": "array",
			"items": {
				"type": "object",
				"required": [
					"id",
					"description",
					"type",
					"status",
					"priority"
				],
				"properties": {
					"id": {
						"type": "string"
					},
					"description": {
						"type": "string"
					},
					"type": {
						"type": "string",
						"enum": [
							"functional",
							"non-functional",
							"constraint",
							"integration"
						]
					},
					"status": {
						"type": "string",
						"enum": [
							"proposed",
							"accepted",
							"deferred",
							"implemented",
							"verified"
						]
					},
					"priority": {
						"type": "string",
						"enum": [
							"must",
							"should",
							"could",
							"wont"
						]
					},
					"acceptance_criteria": {
						"type": "array",
						"items": {
							"type": "string"
						}
					},
					"source": {
						"type": "string",
						"enum": [
							"human",
							"agent",
							"analysis"
						],
						"description": "How this requirement was created"
					},
					"traces_to": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"description": "Phase or task IDs that implement this"
					},
					"depends_on": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"description": "IDs of other requirements this depends on"
					}
				}
			}
		}
	}
}
