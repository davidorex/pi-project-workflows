{
	"name": "@davidorex/pi-context",
	"version": "0.27.0",
	"description": "Schema-driven project state management for Pi",
	"license": "MIT",
	"author": "David Ryan",
	"type": "module",
	"keywords": [
		"pi-package"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/davidorex/pi-project-workflows.git",
		"directory": "packages/pi-context"
	},
	"homepage": "https://github.com/davidorex/pi-project-workflows/tree/main/packages/pi-context",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./block-api": {
			"types": "./dist/block-api.d.ts",
			"default": "./dist/block-api.js"
		},
		"./content-hash": {
			"types": "./dist/content-hash.d.ts",
			"default": "./dist/content-hash.js"
		},
		"./git-env": {
			"types": "./dist/git-env.d.ts",
			"default": "./dist/git-env.js"
		},
		"./object-store": {
			"types": "./dist/object-store.d.ts",
			"default": "./dist/object-store.js"
		},
		"./schema-validator": {
			"types": "./dist/schema-validator.d.ts",
			"default": "./dist/schema-validator.js"
		},
		"./block-validation": {
			"types": "./dist/block-validation.d.ts",
			"default": "./dist/block-validation.js"
		},
		"./context-dir": {
			"types": "./dist/context-dir.d.ts",
			"default": "./dist/context-dir.js"
		},
		"./context-registry": {
			"types": "./dist/context-registry.d.ts",
			"default": "./dist/context-registry.js"
		},
		"./context-sdk": {
			"types": "./dist/context-sdk.d.ts",
			"default": "./dist/context-sdk.js"
		},
		"./context": {
			"types": "./dist/context.d.ts",
			"default": "./dist/context.js"
		},
		"./promote-item": {
			"types": "./dist/promote-item.d.ts",
			"default": "./dist/promote-item.js"
		},
		"./migrate-content-addressed": {
			"types": "./dist/migrate-content-addressed.d.ts",
			"default": "./dist/migrate-content-addressed.js"
		},
		"./canonicalize-substrate": {
			"types": "./dist/canonicalize-substrate.d.ts",
			"default": "./dist/canonicalize-substrate.js"
		},
		"./dispatch-context": {
			"types": "./dist/dispatch-context.d.ts",
			"default": "./dist/dispatch-context.js"
		},
		"./schema-write": {
			"types": "./dist/schema-write.d.ts",
			"default": "./dist/schema-write.js"
		},
		"./schema-migrations": {
			"types": "./dist/schema-migrations.d.ts",
			"default": "./dist/schema-migrations.js"
		},
		"./lens-view": {
			"types": "./dist/lens-view.d.ts",
			"default": "./dist/lens-view.js"
		},
		"./rename-canonical-id": {
			"types": "./dist/rename-canonical-id.d.ts",
			"default": "./dist/rename-canonical-id.js"
		},
		"./samples-catalog": {
			"types": "./dist/samples-catalog.d.ts",
			"default": "./dist/samples-catalog.js"
		},
		"./read-element": {
			"types": "./dist/read-element.d.ts",
			"default": "./dist/read-element.js"
		},
		"./land-identity-fields": {
			"types": "./dist/land-identity-fields.d.ts",
			"default": "./dist/land-identity-fields.js"
		},
		"./schemas/config.schema.json": "./schemas/config.schema.json",
		"./schemas/context-registry.schema.json": "./schemas/context-registry.schema.json",
		"./schemas/relations.schema.json": "./schemas/relations.schema.json",
		"./schemas/priority.schema.json": "./schemas/priority.schema.json",
		"./schemas/status.schema.json": "./schemas/status.schema.json",
		"./schemas/severity.schema.json": "./schemas/severity.schema.json",
		"./schemas/source.schema.json": "./schemas/source.schema.json",
		"./schemas/layer.schema.json": "./schemas/layer.schema.json",
		"./schemas/verification-method.schema.json": "./schemas/verification-method.schema.json"
	},
	"pi": {
		"extensions": [
			"./dist/index.js"
		],
		"skills": [
			"./skills"
		]
	},
	"files": [
		"dist/",
		"skills/",
		"schemas/",
		"samples/",
		"*.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc -p tsconfig.build.json",
		"prepublishOnly": "npm run clean && npm run build",
		"test": "tsx --test src/*.test.ts"
	},
	"dependencies": {
		"@earendil-works/pi-coding-agent": "^0.75.4",
		"typebox": "^1.1.24",
		"ajv": "^8.17.1",
		"ajv-formats": "^3.0.1",
		"canonicalize": "^2.0.0",
		"proper-lockfile": "^4.1.2"
	},
	"devDependencies": {
		"@types/proper-lockfile": "^4.1.4"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
