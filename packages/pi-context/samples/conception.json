  "lenses": [
    {
      "id": "tasks-by-status",
      "kind": "target",
      "target": "tasks",
      "derived_from_field": "status",
      "bins": [
        "planned",
        "in-progress",
        "completed",
        "blocked",
        "cancelled"
      ]
    },
    {
      "id": "gaps-by-status",
      "kind": "target",
      "target": "framework-gaps",
      "derived_from_field": "status",
      "bins": [
        "identified",
        "accepted",
        "in-progress",
        "closed",
        "wontfix"
      ]
    }
  ],
  "layers": [],
  "status_buckets": {},
