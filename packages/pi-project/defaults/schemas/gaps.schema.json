{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"description": "Known deficiencies, missing capabilities, and open issues. What is not right yet. With priority, category, and resolution tracking. The source of truth for what needs fixing or building.",
	"title": "Gaps",
	"type": "object",
	"required": [
		"gaps"
	],
	"properties": {
		"gaps": {
			"type": "array",
			"items": {
				"type": "object",
				"required": [
					"id",
					"description",
					"status",
					"category",
					"priority"
				],
				"properties": {
					"id": {
						"type": "string"
					},
					"description": {
						"type": "string"
					},
					"status": {
						"type": "string",
						"enum": [
							"open",
							"resolved",
							"deferred"
						]
					},
					"category": {
						"type": "string",
						"enum": [
							"missing",
							"incomplete",
							"defect",
							"improvement",
							"technical-debt",
							"question"
						]
					},
					"priority": {
						"type": "string",
						"enum": [
							"low",
							"medium",
							"high",
							"critical"
						]
					},
					"phase": {
						"type": [
							"string",
							"integer"
						],
						"description": "Phase this gap was discovered in or relates to"
					},
					"resolved_by": {
						"type": "string",
						"description": "Task, phase, or decision ID that resolved this"
					},
					"source": {
						"type": "string",
						"enum": [
							"human",
							"agent",
							"monitor",
							"workflow"
						],
						"description": "How this gap was created"
					},
					"details": {
						"type": "string"
					}
				}
			}
		}
	}
}
