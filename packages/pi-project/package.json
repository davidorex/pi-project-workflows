{
  "name": "@davidorex/pi-project",
  "version": "0.2.0",
  "description": "Schema-driven project state management for Pi",
  "license": "MIT",
  "author": "David Ryan",
  "type": "module",
  "keywords": ["pi-package"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidorex/pi-project-workflows.git",
    "directory": "packages/pi-project"
  },
  "homepage": "https://github.com/davidorex/pi-project-workflows/tree/main/packages/pi-project",
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "files": ["src/", "defaults/", "*.md"],
  "scripts": {
    "test": "node --experimental-strip-types --test src/*.test.ts",
    "release": "npx changelogen --bump --release",
    "release:patch": "npx changelogen --bump --release --patch",
    "release:minor": "npx changelogen --bump --release --minor",
    "release:major": "npx changelogen --bump --release --major",
    "release:push": "git push --follow-tags"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  }
}
