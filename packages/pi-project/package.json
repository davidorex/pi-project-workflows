{
	"name": "@davidorex/pi-project",
	"version": "0.9.0",
	"description": "Schema-driven project state management for Pi",
	"license": "MIT",
	"author": "David Ryan",
	"type": "module",
	"keywords": [
		"pi-package"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/davidorex/pi-project-workflows.git",
		"directory": "packages/pi-project"
	},
	"homepage": "https://github.com/davidorex/pi-project-workflows/tree/main/packages/pi-project",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./block-api": {
			"types": "./dist/block-api.d.ts",
			"default": "./dist/block-api.js"
		},
		"./schema-validator": {
			"types": "./dist/schema-validator.d.ts",
			"default": "./dist/schema-validator.js"
		},
		"./block-validation": {
			"types": "./dist/block-validation.d.ts",
			"default": "./dist/block-validation.js"
		},
		"./project-dir": {
			"types": "./dist/project-dir.d.ts",
			"default": "./dist/project-dir.js"
		},
		"./project-sdk": {
			"types": "./dist/project-sdk.d.ts",
			"default": "./dist/project-sdk.js"
		},
		"./sync-skills": {
			"types": "./dist/sync-skills.d.ts",
			"default": "./dist/sync-skills.js"
		}
	},
	"pi": {
		"extensions": [
			"./dist/index.js"
		],
		"skills": [
			"./skills"
		]
	},
	"files": [
		"dist/",
		"skills/",
		"defaults/",
		"*.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc -p tsconfig.build.json",
		"prepublishOnly": "npm run clean && npm run build",
		"test": "tsx --test src/*.test.ts"
	},
	"dependencies": {
		"ajv": "^8.17.1",
		"@mariozechner/pi-coding-agent": "^0.63.1",
		"@sinclair/typebox": "^0.34.48"
	}
}
