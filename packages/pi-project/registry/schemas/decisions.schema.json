{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"description": "Choices made and why. Architectural, technical, and process choices with rationale and status (decided, tentative, revisit). The record of deliberate selection between alternatives. Decisions say what was chosen.",
	"title": "Decisions",
	"type": "object",
	"required": [
		"decisions"
	],
	"properties": {
		"decisions": {
			"type": "array",
			"items": {
				"type": "object",
				"required": [
					"id",
					"decision",
					"rationale",
					"status"
				],
				"properties": {
					"id": {
						"type": "string"
					},
					"decision": {
						"type": "string"
					},
					"rationale": {
						"type": "string"
					},
					"phase": {
						"type": [
							"string",
							"integer"
						]
					},
					"status": {
						"type": "string",
						"enum": [
							"decided",
							"tentative",
							"revisit",
							"superseded"
						]
					},
					"context": {
						"type": "string",
						"description": "What prompted this decision"
					},
					"task": {
						"type": "string",
						"description": "Task ID during which this decision was made"
					}
				}
			}
		}
	}
}
