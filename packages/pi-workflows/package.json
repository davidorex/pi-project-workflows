{
	"name": "@davidorex/pi-workflows",
	"version": "0.13.0",
	"description": "Workflow orchestration extension for Pi",
	"license": "MIT",
	"author": "David Ryan",
	"type": "module",
	"keywords": [
		"pi-package"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/davidorex/pi-project-workflows.git",
		"directory": "packages/pi-workflows"
	},
	"homepage": "https://github.com/davidorex/pi-project-workflows/tree/main/packages/pi-workflows",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./agent-spec": {
			"types": "./dist/agent-spec.d.ts",
			"default": "./dist/agent-spec.js"
		},
		"./template": {
			"types": "./dist/template.d.ts",
			"default": "./dist/template.js"
		},
		"./step-shared": {
			"types": "./dist/step-shared.d.ts",
			"default": "./dist/step-shared.js"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"default": "./dist/types.js"
		}
	},
	"pi": {
		"extensions": [
			"./dist/index.js"
		],
		"skills": [
			"./skills"
		]
	},
	"files": [
		"dist/",
		"skills/",
		"agents/",
		"schemas/",
		"workflows/",
		"templates/",
		"*.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc -p tsconfig.build.json",
		"prepublishOnly": "npm run clean && npm run build",
		"test": "tsx --test src/*.test.ts"
	},
	"dependencies": {
		"nunjucks": "^3.2.4",
		"yaml": "^2.7.1",
		"@davidorex/pi-project": "^0.13.0",
		"@mariozechner/pi-ai": "^0.63.1",
		"@mariozechner/pi-coding-agent": "^0.63.1",
		"@mariozechner/pi-tui": "^0.63.1",
		"@sinclair/typebox": "^0.34.48"
	},
	"devDependencies": {
		"@types/nunjucks": "^3.2.6"
	}
}
